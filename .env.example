# Site URL (used for metadata and OAuth redirects in later phases)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Supabase (dashboard → Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=
# Use the name that matches your Supabase dashboard (any one of these):
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=

# AI providers (Phase 6–7)
# OPENAI_API_KEY=

# Prompt Run — fal.ai FLUX.2 Turbo (https://fal.ai/models/fal-ai/flux-2/turbo)
# FAL_KEY=
# FAL_IMAGE_MODEL=fal-ai/flux-2/turbo
# PROMPT_RUN_GENERATION_ENABLED=true

# Mapbox (https://account.mapbox.com/access-tokens/)
# NEXT_PUBLIC_MAPBOX_TOKEN=pk....   # client map render — URL-restrict in Mapbox dashboard
# MAPBOX_ACCESS_TOKEN=pk....        # server geocoding route
